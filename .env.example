# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# AI Provider 선택
#   gemini : 외부 Google Gemini API (기본값)
#   local  : 사내망 로컬 LLM (OpenAI 호환 엔드포인트: Ollama, vLLM 등)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# ── AI_PROVIDER=gemini 일 때 ──
GEMINI_API_KEY=

# ── AI_PROVIDER=local 일 때 ──
# LOCAL_AI_BASE_URL=http://사내LLM서버:11434/v1   # Ollama 예시 (/v1 까지 포함)
# LOCAL_AI_API_KEY=not-needed                      # 인증 없으면 임의값
# LOCAL_CHAT_MODEL=qwen2.5:14b
# LOCAL_EMBED_MODEL=bge-m3
# EMBEDDING_DIM=1024                               # 임베딩 모델 차원 (bge-m3=1024, gemini=768)
#
# 이미지/PDF 고장보고서 처리용 OCR (로컬은 멀티모달 불가 → OCR 선처리)
# LOCAL_OCR_BASE_URL 가 아니라 OCR_BASE_URL 입니다.
# OCR_BASE_URL=http://사내OCR서버:8080            # POST /ocr (multipart file) → { text }
# OCR_API_KEY=                                     # 인증 있으면
#
# 주의: provider를 바꾸면 임베딩 벡터 공간이 달라집니다.
#       기존 wiki 임베딩을 재생성하고 DB의 vector 차원도 맞춰야 검색이 정상 동작합니다.
#
# 전환 절차:
#   1) (차원이 다르면) supabase/migrations/0006_local_llm_embedding_dim.sql 을
#      모델 차원에 맞게 수정 후 Supabase SQL 에디터에서 실행
#   2) 서버 기동 후  POST /api/wiki/reembed  호출로 전체 임베딩 재생성
#      예: curl -X POST http://localhost:3000/api/wiki/reembed
